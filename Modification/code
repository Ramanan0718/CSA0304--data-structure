#include <stdio.h>

int main()
{
    int a[100], n, pos, value, i;

    scanf("%d", &n);

    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    scanf("%d", &pos);
    scanf("%d", &value);

    if(pos < 1 || pos > n)
    {
        printf("Invalid position");
        return 0;
    }

    a[pos - 1] = value;

    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
